# Line endings — auto-detect dla tekstu, nie konwertuj binarek
* text=auto

# Wymusz LF dla kodu (cross-platform contributors, gdyby pojawili się)
*.cpp text eol=lf
*.h text eol=lf
*.cs text eol=lf
*.ini text eol=lf
*.md text eol=lf

# ===== Unreal content — Git LFS =====
*.uasset filter=lfs diff=lfs merge=lfs -text
*.umap filter=lfs diff=lfs merge=lfs -text

# Images
*.png filter=lfs diff=lfs merge=lfs -text
